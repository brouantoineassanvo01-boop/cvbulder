DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

AI_PROVIDER=groq
GROQ_MODEL=openai/gpt-oss-120b

# Optionnel: remettre AI_PROVIDER=openai pour utiliser OpenAI.
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-5.5
OPENAI_REQUEST_TIMEOUT=60
CV_OCR_LANGUAGES=fra+eng+spa+deu
CV_OCR_MAX_PAGES=6
CV_OCR_DPI=180

PAYSTACK_SECRET_KEY=sk_live_xxx
PAYSTACK_PUBLIC_KEY=pk_live_xxx
PAYSTACK_CURRENCY=XOF
PAYSTACK_CALLBACK_URL=http://localhost:5173/dashboard
PAYSTACK_SUBUNIT_MULTIPLIER=1
PAYMENTS_ENFORCED=false

LIBREOFFICE_BINARY=soffice
CV_HTML_RENDERER=auto
CV_CHROMIUM_BINARY=
CV_SINGLE_PRICE_XOF=200
CV_WEEKLY_PRICE_XOF=500
CV_EXTRA_AI_PRICE_XOF=50
CV_SINGLE_ACCESS_HOURS=2
CV_WEEKLY_ACCESS_HOURS=168
CV_EXTRA_AI_CREDITS=1
CV_TEMPLATE_LIBRARY_DIR=
